generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  CASHIER
}

enum StockMovementType {
  IN
  OUT
  ADJUST
  SALE
  VOID
}

enum VatMode {
  NONE
  INCLUDED
  EXCLUDED
}

enum TabStatus {
  OPEN
  HELD
  MERGED
  CLOSED
  PAID
  VOID
}

enum InvoiceType {
  POS_QUICK
  POS_TAB
  BOOKING
  MIXED
}

enum InvoiceStatus {
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  TRANSFER
  QR
  CARD
  MIXED
  OTHER
}

enum OrderItemStatus {
  ACTIVE
  VOID
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  PAY_IN
  PAY_OUT
}

enum SportType {
  FOOTBALL
  BASKETBALL
  BADMINTON
  TENNIS
  VOLLEYBALL
  SWIMMING
  OTHER
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  points Int @default(0)

  referralCode           String?   @unique
  referredById           String?
  referralBonusGrantedAt DateTime?
  notifEmail             Boolean   @default(true)
  notifInApp             Boolean   @default(true)
  twoFactorSecret        String?
  twoFactorEnabled       Boolean   @default(false)
  twoFactorBackupCodes   String[]  @default([])
  passwordChangedAt      DateTime?

  referredBy        User?              @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         User[]             @relation("Referrals")
  accounts          Account[]
  sessions          Session[]
  bookings          Booking[]
  waitingLists      WaitingList[]
  reviews           Review[]
  notifications     Notification[]
  pointTransactions PointTransaction[]
  pushSubscriptions PushSubscription[]
  conversation      Conversation?
  sentMessages      Message[]          @relation("SentMessages")
  auditLogs         AuditLog[]         @relation("AdminAuditLogs")
}

model Conversation {
  id            String   @id @default(cuid())
  userId        String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  senderRole     String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  type      String // "EARN" | "REDEEM"
  bookingId String?
  note      String
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Notification {
  id             String   @id @default(cuid())
  userId         String
  title          String
  message        String
  isRead         Boolean  @default(false)
  type           String
  link           String?
  conversationId String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Field {
  id           String    @id @default(cuid())
  name         String
  description  String?
  sportType    SportType
  pricePerHour Float
  imageUrl     String?
  images       String[]  @default([])
  location     String?
  facilities   String?
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  openTime     String    @default("08:00")
  closeTime    String    @default("22:00")
  lat          Float?
  lng          Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bookings     Booking[]
  waitingLists WaitingList[]
  reviews      Review[]
  blockedDates FieldBlockedDate[]
  priceRules   FieldPriceRule[]
}

model FieldBlockedDate {
  id        String   @id @default(cuid())
  fieldId   String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, date])
  @@index([fieldId])
}

model FieldPriceRule {
  id           String   @id @default(cuid())
  fieldId      String
  startTime    String
  endTime      String
  pricePerHour Float
  label        String?
  createdAt    DateTime @default(now())

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId])
}

model Booking {
  id                    String        @id @default(cuid())
  userId                String
  fieldId               String
  date                  DateTime
  timeSlot              String
  status                BookingStatus @default(PENDING)
  note                  String?
  isRecurring           Boolean       @default(false)
  recurringGroupId      String?
  stripeSessionId       String?
  stripePaymentIntentId String?
  paidAt                DateTime?
  couponCode            String?
  discountAmount        Float?
  pointsRedeemed        Int?
  pointsEarned          Int?
  reminderSentAt        DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  field             Field              @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  coupon            Coupon?            @relation(fields: [couponCode], references: [code])
  pointTransactions PointTransaction[]

  @@index([fieldId, date])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([recurringGroupId])
  @@index([status, date])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String // "PERCENT" or "FIXED"
  discountValue Float
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings Booking[]
}

model WaitingList {
  id        String   @id @default(cuid())
  userId    String
  fieldId   String
  date      DateTime
  timeSlot  String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, date, timeSlot, userId])
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  fieldId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([userId, fieldId])
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())

  admin User @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PosProduct {
  id            String    @id @default(cuid())
  name          String
  sku           String?   @unique
  category      String?
  price         Float
  cost          Float     @default(0)
  stockQty      Int       @default(0)
  stockUnit     String    @default("ชิ้น")
  lowStockAlert Int       @default(5)
  imageUrl      String?
  isActive      Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Stock-variant: a pack/bundle draws from a base product's stock.
  // stockParentId points to the base product; unitsPerStock = base units consumed per one of this.
  stockParentId String?
  unitsPerStock Int       @default(1)
  stockParent   PosProduct?  @relation("PosStockVariant", fields: [stockParentId], references: [id], onDelete: SetNull)
  stockVariants PosProduct[] @relation("PosStockVariant")

  movements PosStockMovement[]

  @@index([category])
  @@index([isActive])
  @@index([stockParentId])
}

model PosStockMovement {
  id        String            @id @default(cuid())
  productId String
  type      StockMovementType
  qty       Int
  refType   String?
  refId     String?
  note      String?
  userId    String?
  createdAt DateTime          @default(now())

  product PosProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([type])
}

model PosTab {
  id          String    @id @default(cuid())
  code        String?
  name        String
  status      TabStatus @default(OPEN)
  bookingId   String?
  teamLabel   String?
  parentTabId String?
  openedBy    String?
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  note        String?

  parentTab PosTab?        @relation("TabMerge", fields: [parentTabId], references: [id], onDelete: SetNull)
  children  PosTab[]       @relation("TabMerge")
  items     PosOrderItem[]

  @@index([status])
  @@index([bookingId])
  @@index([parentTabId])
}

model PosOrderItem {
  id          String          @id @default(cuid())
  tabId       String
  productId   String
  productName String
  qty         Int
  unitPrice   Float
  discount    Float           @default(0)
  status      OrderItemStatus @default(ACTIVE)
  note        String?
  createdBy   String?
  createdAt   DateTime        @default(now())

  tab PosTab @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@index([tabId])
  @@index([productId])
}

model PosInvoice {
  id              String        @id @default(cuid())
  invoiceNo       String        @unique
  type            InvoiceType
  status          InvoiceStatus @default(PAID)
  subtotalProduct Float         @default(0)
  subtotalBooking Float         @default(0)
  discount        Float         @default(0)
  vatMode         VatMode
  vatRate         Float
  vatAmount       Float         @default(0)
  total           Float
  refundedAmount  Float         @default(0)
  serviceCharge   Float         @default(0)
  totalCost       Float         @default(0)
  pointsEarned    Int           @default(0)
  pointsRedeemed  Int           @default(0)
  pointsRedeemValue Float       @default(0)
  cashierId       String?
  shiftId         String?
  customerId      String?
  customerName    String?
  customerTaxId   String?
  customerAddress String?
  customerPhone   String?
  bookingIds      Json?
  tabIds          Json?
  itemsSnapshot   Json?
  note            String?
  voidReason      String?
  voidedAt        DateTime?
  voidedBy        String?
  relatedInvoiceId String?
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())

  payments PosPayment[]
  splits   PosInvoiceSplit[]
  refunds  PosRefund[]
  shift    PosShift?         @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  relatedInvoice  PosInvoice?  @relation("InvoiceSplit", fields: [relatedInvoiceId], references: [id], onDelete: SetNull)
  linkedInvoices  PosInvoice[] @relation("InvoiceSplit")

  @@index([paidAt])
  @@index([status])
  @@index([type])
  @@index([shiftId])
  @@index([relatedInvoiceId])
}

model PosPayment {
  id           String        @id @default(cuid())
  invoiceId    String
  method       PaymentMethod
  amount       Float
  cashReceived Float?
  changeAmount Float?
  refNo        String?
  paidAt       DateTime      @default(now())

  invoice PosInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PosInvoiceSplit {
  id        String        @id @default(cuid())
  invoiceId String
  label     String
  amount    Float
  method    PaymentMethod
  refNo     String?
  paidAt    DateTime      @default(now())

  invoice PosInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PosShift {
  id            String      @id @default(cuid())
  shiftNo       String      @unique
  cashierId     String
  status        ShiftStatus @default(OPEN)
  openingFloat  Float       @default(0)
  openingNote   String?
  openedAt      DateTime    @default(now())
  closedAt      DateTime?
  closedBy      String?
  countedCash   Float?
  closingNote   String?

  invoices       PosInvoice[]
  refunds        PosRefund[]
  cashMovements  PosCashMovement[]

  @@index([status])
  @@index([openedAt])
  @@index([cashierId])
}

model PosRefund {
  id            String        @id @default(cuid())
  refundNo      String        @unique
  invoiceId     String
  shiftId       String?
  cashierId     String?
  method        PaymentMethod
  amount        Float
  reason        String?
  itemsSnapshot Json?
  createdAt     DateTime      @default(now())

  invoice PosInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shift   PosShift?  @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([shiftId])
  @@index([createdAt])
}

model PosSettings {
  id                 String   @id @default("default")
  shopName           String   @default("88ARENA")
  taxId              String?
  address            String?
  vatMode            VatMode  @default(INCLUDED)
  vatRate            Float    @default(7)
  allowNegativeStock Boolean  @default(false)
  requireShift       Boolean  @default(false)
  pointsEarnPerBaht  Float    @default(0)
  pointsValueBaht    Float    @default(1)
  serviceChargeRate  Float    @default(0)
  printerType        String   @default("BROWSER")
  paperSize          String   @default("80mm")
  receiptHeader      String?
  receiptFooter      String?
  cashDrawerEnabled  Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

model PosCashMovement {
  id        String           @id @default(cuid())
  shiftId   String
  type      CashMovementType
  amount    Float
  reason    String?
  userId    String?
  createdAt DateTime         @default(now())

  shift PosShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId])
  @@index([createdAt])
}

// Webhook event deduplication. INSERT against the unique eventId fails atomically
// when the same Stripe event is delivered twice, letting us short-circuit handler logic.
model ProcessedStripeEvent {
  eventId     String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}
