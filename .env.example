# ============================================================
# 88ARENA - Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# ============================================================

# ---- Database (Neon PostgreSQL recommended) ----------------
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- NextAuth --------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_32_CHAR_RANDOM_SECRET"
NEXTAUTH_URL="https://yourdomain.com"           # http://localhost:3000 for dev

# ---- App URL (used in sitemap, emails, OG tags) ----------------
NEXT_PUBLIC_APP_URL="https://yourdomain.com"    # http://localhost:3000 for dev

# ---- Google OAuth ----------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ---- Stripe (use test keys for dev, live keys for prod) --------
STRIPE_SECRET_KEY="sk_live_..."                 # or sk_test_...
STRIPE_PUBLISHABLE_KEY="pk_live_..."            # or pk_test_...
# Register webhook at: https://dashboard.stripe.com/webhooks
# Event: checkout.session.completed -> https://yourdomain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- Email (Resend) --------------------------------------------
# Verify your domain at: https://resend.com/domains
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# ---- Cloudinary (profile photo uploads) -----------------------
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ---- Upstash Redis (rate limiting) ----------------------------
# Create at: https://console.upstash.com
# Falls back to in-memory if not set (not suitable for multi-instance prod)
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ---- Web Push Notifications (VAPID) ---------------------------
# Generate with: node scripts/generate-vapid.js
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# ---- LINE Notify (optional - admin notifications) -------------
# Get token at: https://notify-bot.line.me/my/
# Leave blank or set to "your-line-notify-token" to disable
LINE_NOTIFY_TOKEN=""

# ---- Sentry (optional - error tracking) ----------------------
NEXT_PUBLIC_SENTRY_DSN=""
